# ──────────────────────────────────────────────────────────────────────────────
# Clinicore-Integrated — Environment Variables
# Copy this file to .env and fill in EVERY value before starting.
# NEVER commit .env to git. Treat this file as the secret manifest.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=clinicore
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=clinicore
# Used by app services (async driver)
DATABASE_URL=postgresql+asyncpg://clinicore:CHANGE_ME_STRONG_PASSWORD@postgres:5432/clinicore

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
RELAYMED_REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
# Dev mode: use dev token. Production: use AppRole or K8s auth.
VAULT_URL=http://vault:8200
VAULT_DEV_TOKEN=CHANGE_ME_VAULT_DEV_TOKEN
VAULT_TOKEN=CHANGE_ME_VAULT_TOKEN
# Path prefix inside Vault where platform secrets are stored
VAULT_MOUNT_PATH=clinicore

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=clinicore
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KC_ADMIN_PASSWORD
KEYCLOAK_CLIENT_ID=clinicore-backend
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KC_CLIENT_SECRET
KEYCLOAK_HOSTNAME=localhost

# ── immudb (WORM audit log) ───────────────────────────────────────────────────
IMMUDB_HOST=immudb
IMMUDB_PORT=3322
IMMUDB_USER=immudb
IMMUDB_PASSWORD=immudb
IMMUDB_DATABASE=clinicore_audit

# ── Qdrant (vector search) ────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── MinIO (object storage) ───────────────────────────────────────────────────
MINIO_URL=http://minio:9000
MINIO_ROOT_USER=clinicore
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET_IMAGES=clinicore-images
MINIO_BUCKET_REPORTS=clinicore-reports

# ── OpenSearch (SIEM telemetry) ───────────────────────────────────────────────
OPENSEARCH_URL=https://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=CHANGE_ME_OPENSEARCH_PASSWORD

# ── AI — Cloud Frontier ──────────────────────────────────────────────────────
# CRITICAL: Ensure a Zero-Data-Retention / no-training agreement is signed
# before any clinical text is sent to a cloud API.
#
# Provider selection. Grok (xAI) is the active cloud LLM — it replaces the
# Google/Gemini path, which was unreliable. Set CLOUD_LLM_PROVIDER=grok.
CLOUD_LLM_PROVIDER=grok           # grok | anthropic

# Grok (xAI) — active provider
GROK_API_KEY=CHANGE_ME_GROK_API_KEY
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-4
GROK_FALLBACK_MODEL=grok-3-mini

# Anthropic (Claude) — kept as an optional alternate provider
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_FALLBACK_MODEL=claude-sonnet-4-6

# ── AI — On-Prem Inference (vLLM) ────────────────────────────────────────────
# Used for raw-PHI paths that must NOT leave the boundary.
ONPREM_LLM_URL=http://vllm:8080
ONPREM_LLM_MODEL=BioMistral-7B-DARE  # or Meditron-70B if GPU allows
ONPREM_LLM_API_KEY=

# ── Model Gateway ─────────────────────────────────────────────────────────────
# Set to "cloud_only" (no on-prem GPU), "onprem_only", or "hybrid" (recommended)
MODEL_GATEWAY_MODE=hybrid
# Sensitivity threshold above which the gateway routes to on-prem instead of cloud
PHI_RISK_THRESHOLD=0.7

# ── Clinicore App ─────────────────────────────────────────────────────────────
CLINICORE_SECRET_KEY=CHANGE_ME_64CHAR_SECRET
MAX_MESSAGES_PER_CHAT=20
MAX_CONTINUATION_DEPTH=5
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years (matches HIPAA; Indian DPDP minimum TBD)
ZERO_RETENTION_TTL_SECONDS=3600
PUBMED_EMAIL=your@email.com  # Required by NCBI E-utilities

# ── RelayMed App ──────────────────────────────────────────────────────────────
RELAYMED_SECRET_KEY=CHANGE_ME_64CHAR_SECRET_2
STALENESS_THRESHOLD_DAYS=30
WEARABLE_AGGREGATOR_API_KEY=  # Terra/Validic/Spike key if using an aggregator
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
GOOGLE_HEALTH_CONNECT_CLIENT_ID=

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PROMETHEUS_URL=http://prometheus:9090

# ── Alerting (on-call) ────────────────────────────────────────────────────────
# Replace Telegram (current SentiHealth) with a real on-call tool
PAGERDUTY_INTEGRATION_KEY=
SLACK_WEBHOOK_URL=

# ── Consent ───────────────────────────────────────────────────────────────────
CONSENT_TEXT_VERSION=1.0.0
DEFAULT_CONSENT_LANGUAGE=en

# ── ABHA / ABDM ───────────────────────────────────────────────────────────────
ABDM_BASE_URL=https://dev.abdm.gov.in
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABHA_GATEWAY_URL=https://dev.abdm.gov.in/gateway

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development  # development | staging | production
LOG_LEVEL=INFO
