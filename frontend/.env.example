# frontend/.env.example  →  copy to frontend/.env and fill in
# All VITE_ vars are PUBLIC (shipped to the browser). Never put a secret key here
# that must stay private — proxy those through the backend / a Supabase Edge Function.

# ── Supabase (system of record for all user data + auth) ────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Agentic AI: LLM provider (Grok / xAI — replaces Google) ─────────────────
# Prefer the proxy so the real key stays server-side.
VITE_AI_PROXY_URL=/api/v1/ai/chat
VITE_GROK_API_BASE=https://api.x.ai/v1

# ── Agentic evidence + learning content ─────────────────────────────────────
VITE_PUBMED_API_KEY=            # optional; only raises NCBI rate limits
VITE_YOUTUBE_API_KEY=           # Clinmed learning videos (YouTube Data API v3)

# ── OAuth / social sign-in (consumer: RelayMed + Clinmed) ───────────────────
# These are the public client IDs. Configure the matching providers in the
# Supabase dashboard (Authentication → Providers); Supabase handles the secret.
VITE_OAUTH_GOOGLE_CLIENT_ID=
VITE_OAUTH_APPLE_CLIENT_ID=
VITE_OAUTH_ENABLE_PHONE_OTP=true          # phone OTP via Supabase Auth
VITE_OAUTH_REDIRECT_URL=http://localhost:5173/auth/callback

# ── OAuth / OIDC (professional: Clinicore clinicians via Keycloak) ──────────
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=clinicore
VITE_KEYCLOAK_CLIENT_ID=clinicore-web     # public SPA client (PKCE)

# ── Backend API bases ───────────────────────────────────────────────────────
VITE_CLINICORE_API_URL=http://localhost:8000
VITE_RELAYMED_API_URL=http://localhost:8001
